<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_inherit" model="ir.ui.view">
        <field name="name">product.template.form.inherit.alzaytoun</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='type']" position="after">
                <field name="project_list_id"/>
            </xpath>

            <xpath expr="//field[@name='purchase_ok']/.." position="after">
                <div class="o_field_widget">
                    <field name="is_real_estate_relative"/>
                    <label for="is_real_estate_relative" string="Is Real Estate Relative"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>